// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id     Int     @id @default(autoincrement())
  email  String  @unique
  name   String?
  posts  Post[]
  habits Habit[]
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String?
  published Boolean @default(false)
  author    User    @relation(fields: [authorId], references: [id])
  authorId  Int
}

model Habit {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String   @db.VarChar(50)
  icon            String // fitness, food, work, health, etc.
  color           String // 12 preset colors
  frequencyType   String // 'daily', 'specific_days', 'custom'
  daysOfWeek      String? // JSON array: ["Monday", "Tuesday", ...] for specific_days
  customFrequency Int? // X times per week for custom frequency
  goal            String? // "Do 50 pushups", "Read 30 pages", etc.
  timeOfDay       String? // 'morning', 'afternoon', 'evening', 'anytime'
  notes           String?  @db.VarChar(200)
  startDate       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}
